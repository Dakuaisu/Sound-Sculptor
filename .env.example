# =============================================================================
# Sound Sculptor — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Flask ---
SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development

# --- Spotify OAuth ---
# Register at https://developer.spotify.com/dashboard
CLIENT_ID=your_spotify_client_id
CLIENT_SECRET=your_spotify_client_secret

# --- OpenAI (optional, for AI playlist generation) ---
OPENAI_API_KEY=your_openai_api_key

# --- URLs ---
# Frontend URL (where users are redirected after OAuth)
FRONTEND_URL=http://localhost:5173

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Docker production overrides ---
# When running with docker-compose, these are auto-set:
# FRONTEND_URL=http://localhost
# CORS_ORIGINS=http://localhost
